{
  "name": "decky-plugin-studio",
  "version": "0.3.1",
  "private": true,
  "description": "VS Code extension for Decky plugin development (also works in Cursor)",
  "license": "Apache-2.0",
  "scripts": {
    "build": "pnpm -r run build",
    "build:extension": "pnpm --filter decky-plugin-studio-extension run build",
    "build:mcp": "pnpm --filter @decky-plugin-studio/mcp run build",
    "build:preview": "pnpm --filter @decky-plugin-studio/preview-server run build",
    "package:vsix": "pnpm --filter decky-plugin-studio-extension run package",
    "package:mcp": "pnpm --filter @decky-plugin-studio/mcp run pack",
    "deploy:vscode": "node scripts/deploy-to-vscode.mjs",
    "deploy:vscode:build-only": "node scripts/deploy-to-vscode.mjs --skip-install",
    "deploy:cursor": "node scripts/deploy-to-cursor.mjs",
    "deploy:cursor:build-only": "node scripts/deploy-to-cursor.mjs --skip-install",
    "dev:preview": "pnpm --filter @decky-plugin-studio/preview-server run dev"
  },
  "engines": {
    "node": ">=18"
  }
}

# Steam Deck SSH connection (for remote deploy from another PC)
DECK_IP=steamdeck.local
# Same-machine Deck (Cursor on Deck): use loopback so build/screenshot skip SSH-to-self
# DECK_IP=127.0.0.1
DECK_PORT=22
DECK_USER=deck
DECK_DIR=/home/deck

# Plugin folder name under ~/homebrew/plugins/ (default: slug from plugin.json "name")
# PLUGIN_NAME=my-plugin

# Cursor debug NDJSON ingest (Deck plugin posts to 127.0.0.1 on the Deck).
# From your PC run: ./scripts/reverse-tunnel-deck-ingest.ps1 (or .sh) so Deck:7682 forwards here.
# DEBUG_INGEST_PORT=7682

# Optional: only if your plugin needs the Deck to reach your PC (e.g. Ollama)
# PC_IP=192.168.1.100
